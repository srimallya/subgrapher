{
  "name": "subgrapher",
  "version": "2.4.7",
  "description": "Subgrapher standalone browser workspace",
  "main": "main.js",
  "author": "Srimallya Maitra",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test:note-pipeline": "node scripts/test_note_pipeline.js",
    "generate:icons:mac": "bash scripts/generate_mac_icons.sh",
    "prepare:llm:mac-arm64": "node scripts/prepare_bundled_llm.js --target darwin-arm64",
    "prepare:llm:win-x64": "node scripts/prepare_bundled_llm.js --target win-x64",
    "prepare:python:mac-arm64": "node scripts/prepare_bundled_python.js --target darwin-arm64",
    "prepare:python:win-x64": "node scripts/prepare_windows_python_or_placeholder.js",
    "build:mac": "npm run generate:icons:mac && npm run prepare:python:mac-arm64 && electron-builder --mac dmg --arm64 --publish never",
    "build:win": "npm run prepare:python:win-x64 && electron-builder --win nsis --x64 --publish never",
    "build:release": "npm run build:mac && npm run build:win"
  },
  "dependencies": {
    "hyperswarm": "^4.17.0",
    "sql.js": "^1.14.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.subgrapher.app",
    "productName": "Subgrapher",
    "copyright": "Copyright © 2026 Srimallya Maitra",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "browser_view_preload.js",
      "renderer/**/*",
      "runtime/**/*",
      "scripts/**/*",
      "assets/**/*",
      "config/**/*",
      "subgrapher_logo.jpg",
      "package.json",
      "package-lock.json"
    ],
    "extraResources": [
      {
        "from": "build/bundled-python/current",
        "to": "python",
        "filter": [
          "**/*"
        ]
      }
    ],
    "protocols": [
      {
        "name": "Subgrapher Invite",
        "schemes": [
          "subgrapher"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icons/app-icon.icns",
      "artifactName": "Subgrapher-${version}-mac.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 140,
          "y": 220
        },
        {
          "x": 420,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 280,
          "y": 360,
          "type": "file",
          "path": "release/instruction.txt"
        }
      ]
    },
    "win": {
      "icon": "assets/icons/app-icon.ico",
      "artifactName": "Subgrapher-${version}-setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
